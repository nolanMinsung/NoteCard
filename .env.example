# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real values.

# === App Store Connect API Key ===
# Get these from App Store Connect → Users and Access → Integrations → App Store Connect API
ASC_KEY_ID=
ASC_ISSUER_ID=
# Path to the .p8 file. Recommended: ~/.appstoreconnect/AuthKey_<KEY_ID>.p8
ASC_KEY_FILEPATH=

# === fastlane match ===
# Strong password for encrypting the certificate vault.
# Store this in 1Password / keychain — losing it means re-creating all certificates.
MATCH_PASSWORD=

# === Apple ID ===
# App Store Connect login email
FASTLANE_USER=mskim4048@naver.com
