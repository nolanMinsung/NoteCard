default_platform(:ios)

VERSION_XCCONFIG = File.expand_path('../Configs/Version.xcconfig', __dir__)
TARGET_NAME = "NoteCard"

# Tuist generates NoteCard.xcodeproj from Project.swift; pbxproj is .gitignored.
# Version/build numbers live in Configs/Version.xcconfig and are edited via regex.
def read_xcconfig_value(key)
  content = File.read(VERSION_XCCONFIG)
  match = content.match(/^\s*#{Regexp.escape(key)}\s*=\s*(.+?)\s*$/)
  raise "#{key} not found in #{VERSION_XCCONFIG}" unless match
  match[1].strip
end

def write_xcconfig_value(key, value)
  content = File.read(VERSION_XCCONFIG)
  pattern = /^(\s*#{Regexp.escape(key)}\s*=\s*).+?\s*$/
  raise "#{key} not found in #{VERSION_XCCONFIG}" unless content.match(pattern)
  content = content.sub(pattern, "\\1#{value}")
  File.write(VERSION_XCCONFIG, content)
end

def update_marketing_version(bump_type:)
  current = read_xcconfig_value("MARKETING_VERSION")
  parts = current.split(".").map(&:to_i)
  parts << 0 while parts.length < 3
  case bump_type
  when "major" then parts[0] += 1; parts[1] = 0; parts[2] = 0
  when "minor" then parts[1] += 1; parts[2] = 0
  else              parts[2] += 1   # patch
  end
  new_version = parts.join(".")
  write_xcconfig_value("MARKETING_VERSION", new_version)
  new_version
end

def set_build_number(value)
  write_xcconfig_value("CURRENT_PROJECT_VERSION", value.to_s)
end

def increment_build_number_xcconfig
  current = read_xcconfig_value("CURRENT_PROJECT_VERSION").to_i
  new_build = current + 1
  write_xcconfig_value("CURRENT_PROJECT_VERSION", new_build.to_s)
  new_build
end

def ensure_xcodeproj_generated
  sh("cd .. && tuist install && tuist generate --no-open")
end

platform :ios do
  before_all do
    # On CI, create a temporary keychain for code signing.
    # On local machine, use the user's login keychain.
    setup_ci if ENV["CI"]
  end

  # ─────────────────────────────────────────────────────────────
  # Helper: load App Store Connect API key from .env
  # ─────────────────────────────────────────────────────────────
  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"],
      duration: 1200,
      in_house: false
    )
  end

  # ─────────────────────────────────────────────────────────────
  # Version / Build number bumping
  # ─────────────────────────────────────────────────────────────

  desc "Increment build number and commit. Run on release branch."
  lane :bump_build do
    build = increment_build_number_xcconfig
    version = read_xcconfig_value("MARKETING_VERSION")
    sh("cd .. && git add Configs/Version.xcconfig && git commit -m 'chore: bump build to #{version} (#{build})'")
  end

  desc "Increment marketing version. Resets build number to 1. Pass type:'patch'|'minor'|'major' (default 'minor'). 'patch' is reserved for hotfix releases."
  lane :bump_version do |options|
    bump_type = options[:type] || "minor"
    version = update_marketing_version(bump_type: bump_type)
    set_build_number(1)
    sh("cd .. && git add Configs/Version.xcconfig && git commit -m 'chore: bump version to #{version}'")
  end

  # ─────────────────────────────────────────────────────────────
  # TestFlight build & upload
  # ─────────────────────────────────────────────────────────────

  desc "Verify build: archive only, no upload, no version bump. Use for fastlane setup validation."
  lane :verify_archive do
    ensure_xcodeproj_generated

    match(
      type: "appstore",
      readonly: true,
      api_key: asc_api_key
    )

    build_app(
      workspace: "NoteCard.xcworkspace",
      scheme: "NoteCard",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.minsung.NoteCard" => "match AppStore com.minsung.NoteCard"
        }
      }
    )
  end

  desc "Build the app and upload to TestFlight. No App Store submission."
  lane :beta do
    if ENV["GITHUB_RUN_NUMBER"]
      # On CI: use GitHub run number as build number (always monotonically increasing).
      # No commit/push back — xcconfig edit is ephemeral on the CI runner.
      set_build_number(ENV["GITHUB_RUN_NUMBER"])
      UI.message("CI mode — build number set to GITHUB_RUN_NUMBER=#{ENV['GITHUB_RUN_NUMBER']}")
    else
      bump_build
    end

    ensure_xcodeproj_generated

    match(
      type: "appstore",
      readonly: true,
      api_key: asc_api_key
    )

    build_app(
      workspace: "NoteCard.xcworkspace",
      scheme: "NoteCard",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.minsung.NoteCard" => "match AppStore com.minsung.NoteCard"
        }
      }
    )

    upload_to_testflight(
      api_key: asc_api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true            # Do NOT submit for App Store review (manual step)
    )
  end

  # ─────────────────────────────────────────────────────────────
  # Metadata / screenshots only (no binary)
  # ─────────────────────────────────────────────────────────────

  desc "Upload App Store metadata and screenshots only (no binary)."
  lane :metadata do
    upload_to_app_store(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      submit_for_review: false,
      force: true                      # Skip HTML preview confirmation
    )
  end

  # ─────────────────────────────────────────────────────────────
  # First-time / maintenance lanes
  # ─────────────────────────────────────────────────────────────

  desc "Initial match setup. Run once. Generates dev + appstore certs/profiles and pushes to the cert repo."
  lane :match_setup do
    match(type: "development", api_key: asc_api_key)
    match(type: "appstore", api_key: asc_api_key)
  end

  desc "Sync existing local metadata/screenshots from App Store Connect to local files."
  lane :pull_metadata do
    sh("cd .. && bundle exec fastlane deliver download_metadata --api-key-path /tmp/asc_api_key.json --force")
    sh("cd .. && bundle exec fastlane deliver download_screenshots --api-key-path /tmp/asc_api_key.json --force")
  end
end
